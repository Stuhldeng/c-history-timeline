{
  "_meta": {
    "name": "column-map",
    "version": "0.7.0",
    "description": "列定义。每列对应一个 mergeGroup，列操作（隐藏/固定/排序）作用于 columnId。",
    "pinnedMax": 3,
    "note": "columnId 格式为 col-{mergeGroup}。前端 columnState 中的 hiddenColumnIds、pinnedColumnIds、manualOrder 均使用 columnId。",
    "rules": {
      "naming": "columnId 格式为 col-{mergeGroup}，mergeGroup 即为前端 getMergeGroups() 使用的组名",
      "visibility": "用户隐藏/固定/排序操作作用于 columnId。hiddenColumnIds 与 pinnedColumnIds 冲突时，pinned 优先（隐藏已固定的列视为取消固定）",
      "pinned": "最多固定 3 列（pinnedMax=3）。固定列始终显示在表格最左侧，不受滚动影响",
      "search": "搜索跳转时，若目标政权的列已隐藏，需临时显示该列或提示用户。建议行为：自动临时取消隐藏，持续到下次手动调整",
      "label": "列的对外展示名称。通常等于 mergeGroup。中央王朝可加星标或其他视觉标识"
    }
  },
